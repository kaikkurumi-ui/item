<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aisia.item.module.mapper.TestMapper">


    <insert id="insert" parameterType="com.aisia.item.module.entity.TestEntity" useGeneratedKeys="true" keyProperty="id">
        insert into test (
        <trim suffixOverrides=",">
            <if test="name != null and name != ''">
                `name`,
            </if>
            <if test="age != null">
                age,
            </if>
            <if test="clazz != null and clazz != ''">
                clazz,
            </if>
            <if test="createTime != null">
                create_time,
            </if>
            <if test="updateTime != null">
                update_time,
            </if>
            is_deleted,
        </trim>
        ) VALUES (
        <trim suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="age != null">#{age},</if>
            <if test="clazz != null and clazz != ''">#{clazz},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            #{isDeleted},
        </trim>
        )
    </insert>

    <update id="update" parameterType="com.aisia.item.module.entity.TestEntity">
        update test
        <set>
            <if test="name != null and name != ''">
                `name` = #{name},
            </if>
            <if test="age != null">
                age = #{age},
            </if>
            <if test="clazz != null and clazz != ''">
                clazz = #{clazz},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="isDeleted != null">
                is_deleted = #{isDeleted},
            </if>
        </set>
        where id = #{id}
    </update>
</mapper>
